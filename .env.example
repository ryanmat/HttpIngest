# Description: Example environment variables for HttpIngest
# Description: Copy to .env and customize for your environment

# ============================================================================
# Application
# ============================================================================
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ============================================================================
# API Authentication (required)
# ============================================================================
# Shared bearer token. Callers must send `Authorization: Bearer <token>`.
# Generate a strong value:  openssl rand -hex 32
# When unset, /api/HttpIngest fails closed with HTTP 503.
INGEST_BEARER_TOKEN=

# ============================================================================
# Azure Data Lake Gen2 (required)
# ============================================================================
# Storage account name (no defaults: set this for your deployment)
DATALAKE_ACCOUNT=
DATALAKE_FILESYSTEM=metrics
DATALAKE_BASE_PATH=otlp

# Buffer flush settings
DATALAKE_FLUSH_INTERVAL_SECONDS=600
DATALAKE_FLUSH_THRESHOLD_ROWS=50000

# Toggle Data Lake writes (primary storage; should remain true)
WRITE_TO_DATALAKE=true

# ============================================================================
# Azure Authentication
# ============================================================================
# Use managed identity in production. Locally, DefaultAzureCredential will
# fall back to az CLI / env / VS Code credentials.
USE_MANAGED_IDENTITY=true

# ============================================================================
# OpenTelemetry Tracing
# ============================================================================
OTEL_TRACING_ENABLED=true
OTEL_SERVICE_NAME=httpingest
OTEL_SERVICE_NAMESPACE=httpingest

# Exporter type: "otlp" or "console"
OTEL_EXPORTER_TYPE=console

# When OTEL_EXPORTER_TYPE=otlp, point at your OpenTelemetry Collector / backend.
# To run a Collector as a sidecar in the same Container App, have it listen on
# localhost:4318 and set the endpoint below so the app exports to the sidecar,
# which then forwards to your tracing backend. See docs/deployment.md.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Optional headers (e.g. authorization for hosted backends). With a sidecar
# Collector, leave unset and let the Collector hold the backend credentials as
# a Container App secret.
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer your-token

# Sampling rate (0.0-1.0)
OTEL_TRACES_SAMPLER_ARG=1.0
