# ABOUTME: Example environment variables for LogicMonitor Data Pipeline
# ABOUTME: Copy to .env and customize for your local development environment

# ============================================================================
# Database Configuration (Local Development)
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_CONN_STR=postgresql://postgres:postgres@localhost:5432/postgres

# ============================================================================
# Database Configuration (Azure Production)
# ============================================================================
# POSTGRES_HOST=rm-postgres.postgres.database.azure.com
# POSTGRES_DB=postgres
# POSTGRES_USER=ryan.matuszewski@logicmonitor.com
# POSTGRES_PORT=5432
# # Get token: az account get-access-token --resource https://ossrdbms-aad.database.windows.net --query accessToken --output tsv
# POSTGRES_PASSWORD=
# POSTGRES_CONN_STR=postgresql://ryan.matuszewski@logicmonitor.com@rm-postgres.postgres.database.azure.com:5432/postgres

# Legacy PostgreSQL environment variables (for compatibility)
PGHOST=localhost
PGDATABASE=postgres
PGUSER=postgres
PGPORT=5432
PGPASSWORD=postgres

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379
USE_REDIS=true

# ============================================================================
# Application Settings
# ============================================================================
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ============================================================================
# Azure Functions (Local Development)
# ============================================================================
AzureWebJobsStorage=UseDevelopmentStorage=true
FUNCTIONS_WORKER_RUNTIME=python

# ============================================================================
# Real-time Streaming Configuration
# ============================================================================
# Maximum WebSocket connections
MAX_WEBSOCKET_CONNECTIONS=100

# Rate limiting (messages per second per client)
RATE_LIMIT_MESSAGES_PER_SECOND=10
RATE_LIMIT_BURST_SIZE=20

# Message buffer size (max messages buffered per client)
MESSAGE_BUFFER_SIZE=1000

# Client state retention (hours)
CLIENT_STATE_RETENTION_HOURS=24

# ============================================================================
# Webhook Configuration (Optional)
# ============================================================================
# WEBHOOK_SECRET=your-webhook-secret-here
# WEBHOOK_TIMEOUT_SECONDS=30
# WEBHOOK_MAX_RETRIES=3

# ============================================================================
# Export Configuration (Optional)
# ============================================================================
# Maximum rows for CSV export
# CSV_MAX_ROWS=100000

# Maximum rows for PowerBI export
# POWERBI_MAX_ROWS=10000

# ============================================================================
# Background Task Configuration
# ============================================================================
# Data processing loop interval (seconds)
DATA_PROCESSING_INTERVAL=30

# Metric publishing loop interval (seconds)
METRIC_PUBLISHING_INTERVAL=10

# Health monitoring interval (seconds)
HEALTH_MONITORING_INTERVAL=60
