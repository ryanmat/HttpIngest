# Staging Environment Configuration
ENVIRONMENT=staging

# Database (Azure PostgreSQL)
POSTGRES_HOST=rm-postgres.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres_staging
POSTGRES_USER=ryan.matuszewski@logicmonitor.com
USE_AZURE_AD_AUTH=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (Azure Cache for Redis)
REDIS_URL=rediss://lm-data-pipeline-redis.redis.cache.windows.net:6380
USE_REDIS=true
REDIS_MAX_CONNECTIONS=50

# Streaming (Production-like limits)
MAX_WEBSOCKET_CONNECTIONS=500
RATE_LIMIT_MESSAGES_PER_SECOND=50
RATE_LIMIT_BURST_SIZE=100
MESSAGE_BUFFER_SIZE=1000
CLIENT_STATE_RETENTION_HOURS=24

# Background Tasks (Production intervals)
DATA_PROCESSING_INTERVAL=30
METRIC_PUBLISHING_INTERVAL=10
HEALTH_MONITORING_INTERVAL=60

# Logging (Info level)
LOG_LEVEL=INFO
LOG_SQL_QUERIES=false

# Application Insights (Enabled for staging)
ENABLE_APP_INSIGHTS=true
# APPLICATIONINSIGHTS_CONNECTION_STRING=<set-in-azure-key-vault>

# Security (Production-like)
REQUIRE_HTTPS=true
CORS_ORIGINS=https://staging.logicmonitor.com,https://staging-grafana.logicmonitor.com
# API_KEYS=<set-in-azure-key-vault>
# WEBHOOK_SECRET=<set-in-azure-key-vault>

# Application
APP_VERSION=12.0.0-staging
DEBUG=false
